  },
  "scripts": {
    "start": "GENERATE_SOURCEMAP=false node scripts/start.js",
    "build": "GENERATE_SOURCEMAP=false node scripts/build.js",
    "prod": "env-cmd -f .env.prod yarn build",
    "dev": "env-cmd -f .env.dev yarn build",
    "test": "node scripts/test.js",
    "postinstall": "husky install",
    "lint": "xo src",
    "lint-summary": "xo src | xo-summary"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
